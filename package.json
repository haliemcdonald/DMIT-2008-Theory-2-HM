{
  "name": "theory-2-jan-2026",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "predev": "pnpm unocss:build",
    "dev": "concurrently \"pnpm unocss:watch\" \"next dev\"",
    "prebuild": "pnpm unocss:build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "unocss:build": "unocss \"src/**/*.{js,jsx,ts,tsx}\" --config unocss.config.js -o src/styles/unocss.css",
    "unocss:watch": "unocss \"src/**/*.{js,jsx,ts,tsx}\" --config unocss.config.js -w -o src/styles/unocss.css"
  },
  "dependencies": {
    "dayjs": "1.11.20",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0"
  },
  "devDependencies": {
    "@unocss/cli": "^66.6.7",
    "@unocss/postcss": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "@unocss/reset": "^66.6.7",
    "@unocss/webpack": "^66.6.7",
    "concurrently": "^9.2.1",
    "eslint": "^10",
    "eslint-config-next": "16.2.2",
    "unocss": "^66.6.7"
  }
}
